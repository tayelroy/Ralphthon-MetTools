PRIVATE_KEY=your_private_key_here
# Solana wallet private key, base58 string or uint8 array JSON
RPC_URL=https://api.devnet.solana.com
# Solana RPC endpoint
NETWORK=devnet
# Solana cluster: devnet or mainnet-beta
MCP_PORT=3000
# HTTP port for the MCP server
MAX_RETRIES=3
# Harness retry cap
OPENAI_API_KEY=your_openai_api_key_here
# API key used by the harness parse/recover stages
